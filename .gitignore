# Binary archives
*.tar.gz

# Environment files
.env
.env.*
!.env.example
supabase/functions/.env
googlekey.json
supabase/.env.local
.secrets.env

# Per-machine Supabase CLI state (version pin + local project link)
supabase/.temp/

# Claude Code session state
.claude/scheduled_tasks.lock

# Large convergence video sources (stored on Supabase Storage, not git).
# Final MP3 + JSON + prompts are tracked; intermediate MP4s are not.
marketing/convergence_videos/**/Video*.mp4
marketing/convergence_videos/**/crossfaded.mp4
marketing/convergence_videos/**/final_*.mp4
marketing/convergence_videos/**/onemind_convergence_*.mp4
marketing/convergence_videos/**/video.mp4
marketing/convergence_videos/**/concat_list.txt

# Firebase platform config (contains API keys)
lib/firebase_options.dart
android/app/google-services.json

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# E2E Tests (Playwright)
e2e/node_modules/
e2e/test-results/
e2e/playwright-report/
e2e/blob-report/
e2e/.env
!e2e/.env.example
